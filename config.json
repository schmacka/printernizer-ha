{
  "name": "Printernizer",
  "version": "0.0.6",
  "slug": "printernizer",
  "description": "Run Printernizer as a Home Assistant addon.",
  "url": "https://github.com/schmacka/printernizer",
  "image": "ghcr.io/schmacka/printernizer-ha-{arch}",
  "startup": "services",
  "boot": "auto",
  "init": false,
  "watchdog": "http://[HOST]:[PORT:8000]/health",
  "webui": "http://[HOST]:[PORT:8000]/",
  "ingress": true,
  "ingress_port": 8000,
  "panel_icon": "mdi:printer-3d",
  "arch": [
    "amd64",
    "armv7",
    "aarch64"
  ],
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "Printernizer web interface"
  },
  "map": [
    "config:rw",
    "ssl"
  ],
  "options": {
    "bambu_printers": [],
    "prusa_printers": [],
    "timezone": "Europe/Berlin",
    "vat_rate": 0.19
  },
  "schema": {
    "bambu_printers": [
      {
        "name": "str",
        "ip": "str",
        "access_code": "str"
      }
    ],
    "prusa_printers": [
      {
        "name": "str",
        "ip": "str",
        "api_key": "str"
      }
    ],
    "timezone": "str",
    "vat_rate": "float"
  }
}
